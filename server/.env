# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5005

# ── MySQL Database (Vultr) ────────────────────────────────────────────────────
DB_HOST=139.84.209.206
DB_PORT=3306
DB_USER=posuser
DB_PASSWORD=PosPass123!
DB_NAME=kagzso_pos
# ── Auth ──────────────────────────────────────────────────────────────────────
