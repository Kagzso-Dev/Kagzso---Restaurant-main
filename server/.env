# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5005

# ── MySQL Database (Vultr) ────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kagzso_pos
DB_USER=root
DB_PASSWORD=Ragul@2004
# ── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a long random secret (e.g. openssl rand -hex 64)
JWT_SECRET=supersecretkey123

# ── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=https://kagzso-pos-frontend.onrender.com

# ── Proxy / Rate Limiting ─────────────────────────────────────────────────────
TRUST_PROXY=1
RATE_LIMIT_MAX=300

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
